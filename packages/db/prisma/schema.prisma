

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid()) 
  email    String @unique              
  password String
  name     String
  rooms    Room[]
  chats    Chat[]
}

model Room {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  createdAt DateTime @default(now())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  chats     Chat[]   // Added this back-relation
}

model Chat {
  id        String   @id @default(uuid()) 
  message   String
  roomId    Int
  userId    String
  createdAt DateTime @default(now())      
  
  room      Room     @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id]) // Fixed UserId -> userId
}
